DATA_DIR=data
CORS_ORIGIN=http://localhost:5173
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT=45
OLLAMA_NUM_PREDICT=1500
MAX_RETRIES=2
MAX_FILE_SIZE=1000000
EXTRACTION_RULES=Extract a people profile from the raw text. Return JSON only. Include id when present, name, contact details, location, notes, and any other useful fields inferred from context. Keep ambiguous values in notes or raw_fields.
