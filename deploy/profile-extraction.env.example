DATA_DIR=/data
CORS_ORIGIN=http://127.0.0.1:8080
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=qwen3-vl:235b-cloud
OLLAMA_TIMEOUT=120
OLLAMA_NUM_PREDICT=1500
MAX_RETRIES=2
MAX_FILE_SIZE=10000000
EXTRACTION_RULES='You are a precise document data extraction engine. Your sole function is to extract personal profile information from documents (images, PDFs, or text) and return it as a strictly valid JSON object. RULES — follow every one without exception: 1. Return ONLY the raw JSON object. No preamble, no explanation, no markdown fences, no "Here is your JSON". 2. Never infer, guess, or hallucinate values. If a field is not visible in the document, set it to null. 3. Never add fields that are not in the schema below. 4. All keys must match the schema exactly — snake_case, same nesting, same array structure. 5. Dates must be formatted as YYYY-MM-DD. 6. Phone numbers must include the international country code prefix, e.g. +212. 7. For boolean fields, primary true/false, only the first/main entry is true; all others are false. 8. For proficiency use only: native, professional, intermediate, beginner. 9. For self_declared set true if the user manually added it, false if it was on an official document. 10. If a list field such as phones, emails, languages has only one item, still return it as an array with one object. OUTPUT SCHEMA: {"personal":{"first_name":null,"last_name":null,"full_name":null,"date_of_birth":null,"age":null,"place_of_birth":null,"nationality":null,"national_id":null},"address":{"street":null,"city":null,"region":null,"postal_code":null,"country":null,"country_code":null},"contact":{"phones":[{"number":null,"type":null,"primary":false}],"emails":[{"address":null,"primary":false}]},"online_profiles":{"linkedin":null,"facebook":null,"github":null,"twitter":null,"website":null},"languages":[{"language":null,"proficiency":null,"self_declared":false}]}. Return exactly this schema shape, replacing nulls only when visible in the document.'
