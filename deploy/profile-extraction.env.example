DATA_DIR=/data
CORS_ORIGIN=http://127.0.0.1:8080
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=qwen3-vl:235b-cloud
OLLAMA_TIMEOUT=300
OLLAMA_STREAM=true
OLLAMA_NUM_PREDICT=600
OLLAMA_NUM_CTX=4096
PROMPT_MAX_LINES_PER_DOC=80
PROMPT_MAX_CHARS=6000
MAX_RETRIES=2
MAX_FILE_SIZE=10000000
EXTRACTION_RULES='Be strict and evidence-based. Return JSON only. Dates must use YYYY-MM-DD when visible. Phone numbers should include an international country code when it is visible or directly implied by the document. Normalize geography when unambiguous from visible city, region, postal code, phone/calling code, or country code. country_code must be ISO alpha-2, not a phone code. Never place country/city/region/postal data or nested objects in street.'
